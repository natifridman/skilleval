{
  "name": "skilleval",
  "version": "0.1.0",
  "description": "Linter, scorer, and evaluator for AI agent skill files (Agent Skills spec)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skilleval": "./bin/skilleval.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "skills",
    "agent-skills",
    "agentskills",
    "lint",
    "linter",
    "evaluator",
    "validator",
    "cli",
    "sarif",
    "security",
    "claude",
    "cursor",
    "copilot",
    "ai-agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "commander": "^14.0.0",
    "gray-matter": "^4.0.3",
    "lilconfig": "^3.1.0",
    "node-sarif-builder": "^3.1.0",
    "ora": "^8.1.0",
    "picocolors": "^1.1.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
